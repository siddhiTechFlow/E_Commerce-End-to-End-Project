  "item": [
    {
      "name": "4. List all products with filters",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "pm.test(\"Response time is less than 2000ms.\", function() {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "let response = pm.response.json();\r",
              "\r",
              "pm.test(\"Products list is not empty.\", function(){\r",
              "    pm.expect(response.products.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Products are returned\", function () {\r",
              "    pm.expect(response.products.length).to.eql(response.limit);\r",
              "});\r",
              "\r",
              "pm.test(\"Pagination values are correct\", function () {\r",
              "    pm.expect(response.limit).to.eql(10);\r",
              "    pm.expect(response.skip).to.eql(0);\r",
              "});\r",
              "\r",
              "pm.environment.set(\"productID\", response.products[0].id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products?limit=10&skip=0",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "skip",
              "value": "0"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "5. Get product by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () \r",
              "{\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () \r",
              "{\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "let res = pm.response.json();\r",
              "\r",
              "pm.test(\"Product ID matches environment productID\", function () \r",
              "{\r",
              "    pm.expect(res.id).to.eql(Number(pm.environment.get(\"productID\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Product details are present\", function () \r",
              "{\r",
              "    pm.expect(res).to.have.property(\"title\");\r",
              "    pm.expect(res).to.have.property(\"price\");\r",
              "    pm.expect(res).to.have.property(\"category\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products/{{productID}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products",
            "{{productID}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "6. List all categories",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function()\r",
              "{\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let res = pm.response.json();\r",
              "\r",
              "pm.test(\"The list of categories is not empty.\", function()\r",
              "{\r",
              "    pm.expect(res.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Total number of categories: \" + res.length, function () {\r",
              "    pm.expect(res.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"All Categories are unique.\",function(){\r",
              "    let uniqueCategories = [...new Set(res)];\r",
              "    pm.expect(uniqueCategories.length).to.eql(res.length);\r",
              "});\r",
              "\r",
              "pm.test(\"All Categories are strings.\",function(){\r",
              "    res.forEach(category =>{\r",
              "     pm.expect(category).to.be.a(\"string\")\r",
              "});\r",
              "\r",
              "});\r",
              "\r",
              ""
