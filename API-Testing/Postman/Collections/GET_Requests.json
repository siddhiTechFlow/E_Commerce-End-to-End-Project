    {
      "name": "8. Get current user cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let res = pm.response.json();\r",
              "\r",
              "pm.test(\"Cart belongs to User 5\", function () {\r",
              "    pm.expect(res.carts[0].userId).to.eql(5);\r",
              "});\r",
              "\r",
              "pm.test(\"User has at least one cart\", function () {\r",
              "    pm.expect(res.carts.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Total carts count matches response\", function () {\r",
              "    pm.expect(res.total).to.eql(res.carts.length);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
