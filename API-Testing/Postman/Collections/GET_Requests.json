    {
      "name": "18. Get current user profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let res = pm.response.json();\r",
              "\r",
              "pm.test(\"User ID matches logged in user\", function () {\r",
              "    pm.expect(res.id).to.eql(Number(pm.environment.get(\"userID\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Email is present\", function () {\r",
              "    pm.expect(res.email).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"User name is present\", function () {\r",
              "    pm.expect(res.username).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"First name is present\", function () {\r",
              "    pm.expect(res.firstName).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
